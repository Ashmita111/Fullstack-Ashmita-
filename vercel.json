{
  "version": 2,
  "public": true,
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "^/vite.svg$",
      "dest": "/frontend/dist/vite.svg"
    },
    {
      "src": "^/favicon.ico$",
      "dest": "/frontend/dist/favicon.ico"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
